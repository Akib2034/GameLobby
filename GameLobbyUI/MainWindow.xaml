<Window x:Class="GameLobbyUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GameLobby" Height="450" Width="800">
    <Grid Margin="-30,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="29*"/>
            <RowDefinition Height="188*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="38*"/>
            <ColumnDefinition Width="377*"/>
        </Grid.ColumnDefinitions>

        <!-- User Login Section -->
        <Button x:Name="LoginBtn" Content="Log in" HorizontalAlignment="Left" Margin="57,16,0,0" VerticalAlignment="Top" Height="58" Width="100" Click="LoginBtn_Click" Grid.Row="1" Grid.ColumnSpan="2" />
        <TextBox x:Name="UserTB" HorizontalAlignment="Left" Margin="57,33,0,0" VerticalAlignment="Top" Width="201" Height="36" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
        <TextBlock x:Name="UsernameTb" HorizontalAlignment="Left" Margin="57,10,0,0" VerticalAlignment="Top" Height="21" Width="176" Grid.Row="0" Text="Username" Grid.ColumnSpan="2"/>

        <!-- Chatbox and Message Section -->
        <TextBox x:Name="ChatTb" IsReadOnly="True" HorizontalAlignment="Left" Height="234" Margin="190,33,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="385" Grid.Column="1" Grid.RowSpan="2"/>
        <TextBox x:Name="MessageTb" TextWrapping="Wrap" Margin="190,220,44,92" Grid.Column="1" Grid.Row="1"/>

        <!-- Logout and Send Buttons -->
        <Button x:Name="LogoutBtn" Content="Log Out" HorizontalAlignment="Left" Margin="85,16,0,0" VerticalAlignment="Top" Height="58" Width="97" Click="LogoutBtn_Click" Grid.Column="1" Grid.Row="1"/>
        <Button x:Name="SendBtn" Content="Send" HorizontalAlignment="Left" Margin="505,289,0,0" VerticalAlignment="Top" Height="58" Width="100" Click="SendBtn_Click" Grid.Column="1" Grid.Row="1"/>

        <!-- Chatroom Creation Section -->
        <Button x:Name="CreateChatroomBtn" Content="Create Chatroom" HorizontalAlignment="Left" Margin="57,125,0,0" VerticalAlignment="Top" Height="58" Width="100" Click="CreateChatroomBtn_Click" Grid.Row="1" Grid.ColumnSpan="2"/>
        <TextBox x:Name="CreateChatroomTb" HorizontalAlignment="Left" Margin="57,93,0,0" VerticalAlignment="Top" Width="201" Height="27" Grid.Row="1" Grid.ColumnSpan="2"/>
        <TextBlock x:Name="EnterChatroomTb" HorizontalAlignment="Left" Margin="57,74,0,0" VerticalAlignment="Top" Height="16" Width="174" Grid.Row="1" Text="Enter Chatroom" Grid.ColumnSpan="2"/>

        <!-- Chatroom User List -->
        <ListView x:Name="ChatroomUsersLv" HorizontalAlignment="Left" Height="192" Margin="580,33,0,0" VerticalAlignment="Top" Width="130" Grid.Column="1" Grid.RowSpan="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Users" Width="100" DisplayMemberBinding="{Binding}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Chatroom List -->
        <ListBox x:Name="ChatroomsLb" HorizontalAlignment="Left" Height="161" Margin="57,188,0,0" VerticalAlignment="Top" Width="201" SelectionChanged="ChatroomsLb_Selection" Grid.Row="1" Grid.ColumnSpan="2"/>

        <!-- Chatroom Control Buttons -->
        <Button x:Name="LeaveChatroomBtn" Content="Leave Chatroom" HorizontalAlignment="Left" Margin="85,125,0,0" VerticalAlignment="Top" Height="58" Width="97" Click="LeaveChatroomBtn_Click" Grid.Column="1" Grid.Row="1"/>
        <Button x:Name="UploadFileBtn" Content="Upload File" HorizontalAlignment="Left" Height="58" Width="100" Margin="400,289,0,0" VerticalAlignment="Top" Click="UploadFileBtn_Click" Grid.Column="1" Grid.Row="1"/>
        <Button x:Name="ChatroomFilesBtn" Content="Chatroom Files" HorizontalAlignment="Left" Height="58" Width="100" Margin="295,289,0,0" VerticalAlignment="Top" Click="ChatroomFilesBtn_Click" Grid.Column="1" Grid.Row="1"/>
        <Button x:Name="RefreshBtn" Content="Refresh" HorizontalAlignment="Left" Margin="190,290,0,0" VerticalAlignment="Top" Height="58" Width="100" Click="RefreshBtn_Click" Grid.Column="1" Grid.Row="1"/>

        <!-- Private Message Section -->
        <Button x:Name="PrivateMessageBtn" Content="PrivateMessage" HorizontalAlignment="Left" Margin="610,289,0,0" VerticalAlignment="Top" Height="58" Width="100" Click="PrivateMessageBtn_click" Grid.Column="1" Grid.Row="1"/>
        <TextBox x:Name="PrivateMessageTb" HorizontalAlignment="Left" Margin="580,190,0,0" VerticalAlignment="Top" Width="130" Height="19" Grid.Column="1" Grid.Row="1"/>
        <TextBlock x:Name="PrivateMessageUserTb" HorizontalAlignment="Left" Margin="580,172,0,0" VerticalAlignment="Top" Width="130" Grid.Column="1" Grid.Row="1" Text="PrivateMessage User" Height="16"/>

        <!-- Chatroom Info -->
        <TextBlock x:Name="ChatroomNameTb" HorizontalAlignment="Left" Margin="190,10,0,0" VerticalAlignment="Top" Grid.Column="1" Height="16" Width="90" Text="Chatroom Name"/>
    </Grid>
</Window>
